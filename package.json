    "@vitejs/plugin-vue": "^6",
    "@vue-tui/cli": "^0.0.3",
    "@vue-tui/testing": "^0.0.3",
    "typescript": "~6.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.8.0"
