{
  "name": "machud",
  "version": "0.0.0",
  "description": "A beautiful, zero-config terminal system monitor for macOS — a TUI reimagining of Stats.",
  "type": "module",
  "bin": {
    "machud": "dist/machud.mjs"
  },
  "files": [
    "dist",
    "DESIGN.md"
